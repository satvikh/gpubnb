{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ComputeBNB Provider",
  "version": "0.1.0",
  "identifier": "dev.computebnb.provider",
  "build": {
    "beforeDevCommand": "npm run dev:tauri-web",
    "devUrl": "http://localhost:3001",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next"
  },
  "app": {
    "windows": [
      {
        "title": "ComputeBNB Provider",
        "url": "/provider/auth",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
